---
import BaseLayout from '../layouts/BaseLayout.astro';
import Proceso from '../components/sections/Proceso.astro';
import Pendientes from '../components/sections/Pendientes.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import Input from '../components/ui/Input.astro';
import Select from '../components/ui/Select.astro';
import Textarea from '../components/ui/Textarea.astro';
import Button from '../components/ui/Button.astro';
import SpecSheet from '../components/ui/SpecSheet.astro';
import Alert from '../components/ui/Alert.astro';
import Table from '../components/ui/Table.astro';
import Badge from '../components/ui/Badge.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const c = await reader.singletons.cyberdeck.read();
if (!c) throw new Error('Falta el contenido de cyberdeck (src/data/cyberdeck.yaml).');

const tablaRows = c.tabla.map((r) => [r.os, r.peso, r.bits, r.init]);
const toneFor = (estado: string) =>
  estado === 'decisión' ? 'accent' : estado === 'sistema' ? 'pending' : 'neutral';
---

<BaseLayout
  title="Empezar un cyberdeck — Fauve Bellenger"
  description="Indicaciones para convertir un netbook viejo en cyberdeck: OS, hardware y capas de UI, con los dotfiles como source of truth."
>
  <!-- MASTHEAD -->
  <header class="wrap mast">
    <div class="id">{c.id}</div>
    <h1>{c.titulo}<br /><span class="blue">{c.acento}</span></h1>
    <p class="thesis">{c.thesis}</p>
    <div class="metaline">
      {c.metaline.map((x) => <span><b>{x.k}</b> · {x.v}</span>)}
    </div>
  </header>

  <div class="wrap" style="padding-top:var(--sp-8)">
    <Breadcrumb items={[{ href: '/', label: 'inicio' }, { label: 'cyberdeck' }]} />
  </div>

  <Proceso />

  <!-- FICHA DEL EQUIPO -->
  <section class="wrap" id="ficha">
    <div class="tag"><span class="n">02</span> Ficha del equipo — el punto de partida</div>
    <div class="grid2">
      <div>
        <h2>{c.fichaTitulo}</h2>
        <p>{c.fichaTexto}</p>
      </div>
      <div class="oswin">
        <div class="osbar">
          <span class="dots"><i></i><i></i><i></i></span><span class="title">field-terminal — ~/deck</span>
        </div>
        <div class="osbody mono-spec">
          <div><span class="prompt">fauve@deck</span>:~$ ./deck --info</div>
          <div><span class="warn">!</span> MODELO ......... por completar</div>
          <div><span class="warn">!</span> ESTADO ......... por completar</div>
          <div><span class="prompt">fauve@deck</span>:~$ <span class="cur"></span></div>
        </div>
      </div>
    </div>

    <div class="grid2 ficha-form">
      <div class="deck-form" role="group" aria-label="Ficha del equipo">
        <div class="label-sm">Completa los datos de tu equipo</div>
        <Input label="Modelo" name="modelo" placeholder="Acer Aspire One D255…" />
        <Select
          label="Sistema operativo"
          name="os"
          options={['por definir', 'antiX', 'MX Linux', 'Debian 13', 'Void / Arch + i3']}
        />
        <Textarea label="Estado / notas" name="estado" placeholder="RAM, almacenamiento, batería, WiFi…" />
        <div><Button type="button">guardar ficha</Button></div>
      </div>
      <div>
        <div class="label-sm">Resumen</div>
        <SpecSheet
          items={[
            { key: 'Modelo', empty: true },
            { key: 'Estado', empty: true },
            { key: 'RAM', value: '—', empty: true },
            { key: 'OS', empty: true },
          ]}
        />
        <Alert variant="info" class="mt">Campos por completar hasta confirmar el modelo y el estado del equipo.</Alert>
      </div>
    </div>
  </section>

  <!-- SISTEMA OPERATIVO -->
  <section class="wrap" id="os">
    <div class="tag"><span class="n">03</span> Sistema operativo — según el equipo</div>
    <h2 style="margin-bottom:var(--sp-11)">{c.osTitulo}</h2>
    <div class="vars">
      {
        c.osOpciones.map((o, i) => (
          <div class:list={['var', i === 1 && 'new']}>
            <h3>{o.nombre} <Badge tone="accent" solid>{o.badge}</Badge></h3>
            <div class="src">{o.src}</div>
            <p>{o.texto}</p>
          </div>
        ))
      }
    </div>

    <Table caption="Comparativa rápida" class="mt" columns={['OS', 'Peso', '32-bit', 'init']} rows={tablaRows} />

    <Alert variant="warning" class="mt">CPU de 32-bit: usa Debian 12 o antiX (Debian 13 dejó de soportar i386).</Alert>
    <Alert variant="info" class="mt">
      Decisión gateada por la ficha del equipo (sección 02): se confirma <b>RAM y almacenamiento</b> antes de elegir.
    </Alert>
  </section>

  <!-- PASOS DEL TRASPASO -->
  <section class="wrap" id="traspaso">
    <div class="tag"><span class="n">04</span> Traspaso — el orden de las capas</div>
    <h2 style="margin-bottom:var(--sp-11)">{c.traspasoTitulo}</h2>
    <div class="flow">
      {
        c.pasos.map((s) => (
          <div class="step"><div class="s">{s.capa}</div><h3>{s.titulo}</h3><p>{s.texto}</p></div>
        ))
      }
    </div>
    <h2 style="margin:var(--sp-14) 0 var(--sp-8)">{c.backlogTitulo}</h2>
    <ul class="todo">
      {
        c.backlog.map((it) => (
          <li>
            <span class="k">{it.k}</span><span>{it.texto}</span>
            <Badge class="push" tone={toneFor(it.estado)}>{it.estado}</Badge>
          </li>
        ))
      }
    </ul>
  </section>

  <Pendientes />
</BaseLayout>

<style>
  .ficha-form {
    margin-top: var(--sp-12);
    align-items: start;
  }
  .deck-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }
  .mt {
    margin-top: var(--sp-6);
  }
  ul.todo li :global(.push) {
    margin-left: auto;
    flex: none;
  }
</style>
