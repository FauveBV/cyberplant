---
import BaseLayout from '../layouts/BaseLayout.astro';
import Proceso from '../components/sections/Proceso.astro';
import Pendientes from '../components/sections/Pendientes.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import Input from '../components/ui/Input.astro';
import Select from '../components/ui/Select.astro';
import Textarea from '../components/ui/Textarea.astro';
import Button from '../components/ui/Button.astro';
import SpecSheet from '../components/ui/SpecSheet.astro';
import Alert from '../components/ui/Alert.astro';
import Table from '../components/ui/Table.astro';
import Badge from '../components/ui/Badge.astro';
---

<BaseLayout
  title="Empezar un cyberdeck — Fauve Bellenger"
  description="Indicaciones para convertir un netbook viejo en cyberdeck: OS, hardware y capas de UI, con los dotfiles como source of truth."
>
  <!-- MASTHEAD -->
  <header class="wrap mast">
    <div class="id">CL · 2026 · guía de traspaso</div>
    <h1>Empezar un<br /><span class="blue">cyberdeck.</span></h1>
    <p class="thesis">
      Convertir un netbook viejo en una herramienta para pensar: el mismo sistema de identidad,
      <em>instanciado</em> en la máquina. Los dotfiles, versionados en Git, son la fuente de verdad.
    </p>
    <div class="metaline">
      <span><b>Objetivo</b> · máquina como prueba viva del sistema</span>
      <span><b>Fuente de verdad</b> · dotfiles en Git</span>
      <span><b>Estado</b> · guía en construcción</span>
    </div>
  </header>

  <div class="wrap" style="padding-top:var(--sp-8)">
    <Breadcrumb items={[{ href: '/', label: 'inicio' }, { label: 'cyberdeck' }]} />
  </div>

  <Proceso />

  <!-- FICHA DEL EQUIPO -->
  <section class="wrap" id="ficha">
    <div class="tag"><span class="n">02</span> Ficha del equipo — el punto de partida</div>
    <div class="grid2">
      <div>
        <h2>El hardware<br />define el rumbo.</h2>
        <p>
          La RAM y el almacenamiento disponibles deciden el sistema operativo y el peso de la
          interfaz. Antes de instalar nada, fijamos los datos del equipo. Ambos campos quedan por
          completar hasta confirmar el modelo.
        </p>
      </div>
      <div class="oswin">
        <div class="osbar">
          <span class="dots"><i></i><i></i><i></i></span><span class="title">field-terminal — ~/deck</span>
        </div>
        <div class="osbody mono-spec">
          <div><span class="prompt">fauve@deck</span>:~$ ./deck --info</div>
          <div><span class="warn">!</span> MODELO ......... por completar</div>
          <div><span class="warn">!</span> ESTADO ......... por completar</div>
          <div><span class="prompt">fauve@deck</span>:~$ <span class="cur"></span></div>
        </div>
      </div>
    </div>

    <!-- ficha editable (componentes del sistema) -->
    <div class="grid2 ficha-form">
      <div class="deck-form" role="group" aria-label="Ficha del equipo">
        <div class="label-sm">Completá los datos de tu equipo</div>
        <Input label="Modelo" name="modelo" placeholder="Acer Aspire One D255…" />
        <Select
          label="Sistema operativo"
          name="os"
          options={['por definir', 'antiX', 'MX Linux', 'Debian 13', 'Void / Arch + i3']}
        />
        <Textarea label="Estado / notas" name="estado" placeholder="RAM, almacenamiento, batería, WiFi…" />
        <div><Button type="button">guardar ficha</Button></div>
      </div>
      <div>
        <div class="label-sm">Resumen</div>
        <SpecSheet
          items={[
            { key: 'Modelo', empty: true },
            { key: 'Estado', empty: true },
            { key: 'RAM', value: '—', empty: true },
            { key: 'OS', empty: true },
          ]}
        />
        <Alert variant="info" class="mt">Campos por completar hasta confirmar el modelo y el estado del equipo.</Alert>
      </div>
    </div>
  </section>

  <!-- SISTEMA OPERATIVO -->
  <section class="wrap" id="os">
    <div class="tag"><span class="n">03</span> Sistema operativo — según el equipo</div>
    <h2 style="margin-bottom:var(--sp-11)">Dos caminos</h2>
    <div class="vars">
      <div class="var">
        <h3>antiX / MX <Badge tone="accent" solid>ligero</Badge></h3>
        <div class="src">init sysv/runit · sin systemd · muy bajo consumo</div>
        <p>
          Para hardware modesto: arranca rápido en poca RAM, base Debian estable y herramientas listas.
          El camino seguro si el netbook es muy limitado.
        </p>
      </div>
      <div class="var new">
        <h3>Void / Arch + i3 <Badge tone="accent" solid>a medida</Badge></h3>
        <div class="src">rolling release · runit/systemd · WM en mosaico</div>
        <p>
          Para construir desde abajo: control total de cada capa y un tiling WM (i3) coherente con la
          tesis de exponer las reglas. Pide más trabajo de configuración.
        </p>
      </div>
    </div>

    <Table
      caption="Comparativa rápida"
      class="mt"
      columns={['OS', 'Peso', '32-bit', 'init']}
      rows={[
        ['antiX', 'muy bajo', 'sí', 'sysv/runit'],
        ['MX Linux', 'bajo', 'sí', 'sysv'],
        ['Debian 13', 'medio', 'no', 'systemd'],
        ['Void / Arch + i3', 'a medida', 'según', 'runit/systemd'],
      ]}
    />

    <Alert variant="warning" class="mt">CPU de 32-bit: usá Debian 12 o antiX (Debian 13 dejó de soportar i386).</Alert>
    <Alert variant="info" class="mt">
      Decisión gateada por la ficha del equipo (sección 02): se confirma <b>RAM y almacenamiento</b> antes de elegir.
    </Alert>
  </section>

  <!-- PASOS DEL TRASPASO -->
  <section class="wrap" id="traspaso">
    <div class="tag"><span class="n">04</span> Traspaso — el orden de las capas</div>
    <h2 style="margin-bottom:var(--sp-11)">Capas de la UI</h2>
    <div class="flow">
      <div class="step"><div class="s">CAPA 01</div><h3>WM</h3><p>Gestor de ventanas: i3 / tiling como base del escritorio.</p></div>
      <div class="step"><div class="s">CAPA 02</div><h3>Terminal + shell</h3><p>Emulador y shell con los tokens del sistema.</p></div>
      <div class="step"><div class="s">CAPA 03</div><h3>GTK</h3><p>Tema de aplicaciones coherente con la paleta.</p></div>
      <div class="step"><div class="s">CAPA 04</div><h3>Compositor</h3><p>Transparencias y sombras controladas, sin adorno.</p></div>
      <div class="step"><div class="s">CAPA 05</div><h3>Barra</h3><p>Status bar con la información mínima necesaria.</p></div>
      <div class="step"><div class="s">CAPA 06</div><h3>Login</h3><p>Greeter y lockscreen con la firma generativa.</p></div>
    </div>
    <h2 style="margin:var(--sp-14) 0 var(--sp-8)">Pendientes del traspaso</h2>
    <ul class="todo">
      <li>
        <span class="k">A</span><span>HDD → SSD: la mejora de hardware de mayor impacto antes de instalar.</span>
        <Badge class="push" tone="neutral">hardware</Badge>
      </li>
      <li>
        <span class="k">B</span><span>Elegir OS según la ficha del equipo (antiX/MX vs. Void/Arch+i3).</span>
        <Badge class="push" tone="accent">decisión</Badge>
      </li>
      <li>
        <span class="k">C</span><span>Dotfiles versionados en Git como source of truth: Figma → config → repo.</span>
        <Badge class="push" tone="pending">sistema</Badge>
      </li>
    </ul>
  </section>

  <Pendientes />
</BaseLayout>

<style>
  .ficha-form {
    margin-top: var(--sp-12);
    align-items: start;
  }
  .deck-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }
  .mt {
    margin-top: var(--sp-6);
  }
  /* empuja el badge de estado al extremo del item (reemplaza el viejo .st) */
  ul.todo li :global(.push) {
    margin-left: auto;
    flex: none;
  }
</style>
