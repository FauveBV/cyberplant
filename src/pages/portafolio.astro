---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const p = await reader.singletons.portafolio.read();
if (!p) throw new Error('Falta el contenido de portafolio (src/data/portafolio.yaml).');
---

<BaseLayout
  title="Portafolio — Fauve Bellenger"
  description="Casos de producto y dirección visual, documentados con el sistema. Próximamente."
>
  <header class="wrap mast">
    <div class="id">{p.id}</div>
    <h1>{p.titulo}<br /><span class="blue">{p.acento}</span></h1>
    <p class="thesis">{p.thesis}</p>
    <div class="metaline">
      {p.metaline.map((x) => <span><b>{x.k}</b> · {x.v}</span>)}
    </div>
  </header>

  <section class="wrap" id="casos">
    <div class="tag"><span class="n">··</span> Casos — próximamente</div>
    <h2 style="margin-bottom:var(--sp-11)">Lo que viene</h2>
    <div class="clusters">
      {
        p.casos.map((c) => (
          <div class="cluster soon">
            <div class="num">{c.num}</div>
            <h3>{c.titulo}</h3>
            <div class="prev soon-prev" />
            <span class="polo cold">{c.estado}</span>
            <p>{c.desc}</p>
          </div>
        ))
      }
    </div>
    <p class="copyhint" style="margin-top:var(--sp-9)">
      Plantilla de caso (ejemplo ficticio, para revisar el formato):
      <a href="/portafolio/ejemplo">ver la plantilla →</a>
    </p>
    <p class="copyhint">
      Mientras tanto, recorre el <a href="/sistema">sistema de diseño</a> o el proyecto
      <a href="/cyberdeck">cyberdeck</a>.
    </p>
  </section>
</BaseLayout>
