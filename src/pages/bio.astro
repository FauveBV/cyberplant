---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const bio = await reader.singletons.bio.read();
if (!bio) throw new Error('Falta el contenido de bio (src/data/bio.yaml).');
---

<BaseLayout
  title="Bio — Fauve Bellenger"
  description="Diseñadora de interacción y experiencia (PUCV). Producto end-to-end: funcionalidad, estética y accesibilidad."
>
  <header class="wrap mast">
    <div class="id">{bio.id}</div>
    <h1>{bio.titulo}</h1>
    <p class="thesis">{bio.thesis}</p>
  </header>

  <section class="wrap bio">
    <!-- EDUCACIÓN -->
    <div class="bio-block">
      <div class="tag">Educación</div>
      <ul class="cv">
        {
          bio.educacion.map((e) => (
            <li class="cv-item">
              <div class="cv-head">
                <h3>{e.titulo}</h3>
                <span class="cv-date">{e.fecha}</span>
              </div>
              <div class="cv-org">{e.org}</div>
            </li>
          ))
        }
      </ul>
      <p class="cv-note"><b>Proyecto de título.</b> {bio.proyectoTitulo}</p>
    </div>

    <!-- EXPERIENCIA -->
    <div class="bio-block">
      <div class="tag">Experiencia</div>
      <ul class="cv">
        {
          bio.experiencia.map((x) => (
            <li class="cv-item">
              <div class="cv-head">
                <h3>{x.rol}</h3>
                <span class="cv-date">{x.fecha}</span>
              </div>
              <div class="cv-org">{x.org}</div>
              <ul class="cv-bullets">
                {x.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- HABILIDADES -->
    <div class="bio-block">
      <div class="tag">Habilidades</div>
      <div class="skills">
        <div>
          <div class="label-sm">Técnicas</div>
          <ul class="cv-bullets">{bio.tecnicas.map((s) => <li>{s}</li>)}</ul>
        </div>
        <div>
          <div class="label-sm">Interpersonales</div>
          <ul class="cv-bullets">{bio.interpersonales.map((s) => <li>{s}</li>)}</ul>
        </div>
      </div>
    </div>

    <!-- INTERESES -->
    <div class="bio-block">
      <div class="tag">Intereses</div>
      <ul class="cv-bullets cols">{bio.intereses.map((s) => <li>{s}</li>)}</ul>
    </div>

    <!-- CONTACTO -->
    <div class="bio-block">
      <div class="tag">Contacto</div>
      <ul class="contact">
        {
          bio.contacto.map((c) => (
            <li>
              <span>{c.label}</span>
              {c.href ? (
                <a
                  href={c.href}
                  {...(c.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {c.valor}
                </a>
              ) : (
                <b>{c.valor}</b>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
