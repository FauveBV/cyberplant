---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const caso = await reader.singletons.casoEjemplo.read();
if (!caso) throw new Error('Falta el contenido del caso (src/data/caso-ejemplo.yaml).');
---

<BaseLayout
  title={`${caso.titulo} — Portafolio (ejemplo) · Fauve Bellenger`}
  description="Caso de ejemplo ficticio para revisar la plantilla de proyecto del portafolio."
>
  <article>
    <header class="wrap mast case-hero">
      <div class="id">
        <a href="/portafolio">← Portafolio</a> · caso de ejemplo <span class="ph">(ficticio)</span>
      </div>
      <h1>{caso.titulo}</h1>
      <p class="thesis">{caso.bajada}</p>
      <div class="case-meta">
        {caso.meta.map((m) => (
          <div><span>{m.label}</span><b>{m.valor}</b></div>
        ))}
      </div>
    </header>

    <section class="wrap">
      <figure class="ph-figure ph-cover"><span>Imagen de portada · 16:9</span></figure>
    </section>

    <section class="wrap case-body">
      {
        caso.bloques.map((b) => (
          <div class="case-block">
            <div class="tag"><span class="n">{b.num}</span> {b.titulo}</div>
            <p>{b.texto}</p>
          </div>
        ))
      }
      <ul class="case-metrics">
        {caso.metricas.map((m) => (
          <li><b>{m.valor}</b><span>{m.label}</span></li>
        ))}
      </ul>
    </section>

    <nav class="wrap case-nav" aria-label="Navegación del portafolio">
      <a href="/portafolio">← Volver al portafolio</a>
      <span>Caso siguiente · próximamente</span>
    </nav>
  </article>
</BaseLayout>
