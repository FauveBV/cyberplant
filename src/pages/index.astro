---
import BaseLayout from '../layouts/BaseLayout.astro';
import Specimen from '../components/Specimen.tsx';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const landing = await reader.singletons.landing.read();
if (!landing) throw new Error('Falta el contenido de landing (src/data/landing.yaml).');
const areas = landing.areas;
---

<BaseLayout
  title="Fauve Bellenger — Sistema de identidad"
  description="Identidad visual propia de Fauve Bellenger: design system, cyberdeck, portafolio y bio."
>
  <section class="hero">
    <div class="hero-bg"><Specimen ambient client:idle /></div>
    <div class="hero-content wrap">
      <h1 class="hero-name">
        {landing.nombre.split('\n').map((l, i) => (i > 0 ? <Fragment><br />{l}</Fragment> : l))}
      </h1>
      <p class="hero-thesis">{landing.bajada}</p>
      <nav class="hero-nav" aria-label="Áreas del sitio">
        {
          areas.map((a) => (
            <a href={a.href} class="hero-link">
              <span class="hero-link-label">{a.label}</span>
              <span class="hero-link-desc">{a.desc}</span>
            </a>
          ))
        }
      </nav>
      <a class="hero-firma" href="/sistema#firma">{landing.firmaLink}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    background: #05060a;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  /* scrim para contraste del texto sobre la animación */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(5, 6, 10, 0.88) 0%,
      rgba(5, 6, 10, 0.62) 46%,
      rgba(5, 6, 10, 0.2) 100%
    );
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    /* ventana de animación fija arriba; el contenido (nombre + nav) entra abajo */
    padding-top: 42vh;
    padding-bottom: var(--sp-14);
  }
  @media (max-width: 720px) {
    .hero-content {
      padding-top: 30vh;
    }
  }
  .hero-id {
    font-size: var(--fs-sm);
    letter-spacing: var(--tr-mega);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--sp-8);
  }
  .hero-name {
    font-family: var(--display);
    font-weight: var(--fw-black);
    /* acotado para no desbordar el .wrap (respeta la grilla) */
    font-size: clamp(32px, 6vw, 76px);
    line-height: 0.92;
    letter-spacing: var(--tr-tightest);
    text-transform: uppercase;
    color: #fff;
    overflow-wrap: break-word;
  }
  .hero-thesis {
    font-family: var(--display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-thesis);
    color: #fff;
    margin-top: var(--sp-7);
    max-width: 42ch;
    line-height: var(--lh-display);
  }
  .hero-nav {
    display: flex;
    flex-direction: column;
    margin-top: var(--sp-9);
    border-top: var(--bw) solid rgba(255, 255, 255, 0.18);
    max-width: 660px;
  }
  .hero-link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-5) 0;
    border-bottom: var(--bw) solid rgba(255, 255, 255, 0.18);
    text-decoration: none;
    transition: padding-left var(--dur) var(--ease);
  }
  .hero-link:hover {
    padding-left: var(--sp-6);
    text-decoration: none;
  }
  .hero-link-label {
    font-family: var(--display);
    font-weight: var(--fw-bold);
    /* más chico en desktop; el mínimo (mobile) se mantiene */
    font-size: clamp(22px, 2.8vw, 28px);
    text-transform: uppercase;
    letter-spacing: var(--tr-tight);
    color: #fff;
    transition: color var(--dur) var(--ease);
  }
  .hero-link:hover .hero-link-label {
    color: var(--c-blue-text);
  }
  .hero-link-desc {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.6);
  }
  .hero-firma {
    display: inline-block;
    margin-top: var(--sp-10);
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
  }
  .hero-firma:hover {
    color: #fff;
    text-decoration: none;
  }
</style>
