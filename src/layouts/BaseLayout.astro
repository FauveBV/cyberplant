---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Sistema de identidad visual propia de Fauve Bellenger — documento vivo / pieza de portfolio.',
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>
    <div class="sr-only" id="live" aria-live="polite" aria-atomic="true"></div>
    <Topbar pathname={pathname} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <script>
      // mueve el foco a #main al navegar entre páginas (view transitions)
      document.addEventListener('astro:after-swap', () => {
        const m = document.getElementById('main');
        if (m) m.focus();
      });
    </script>
    <script>
      // scroll suave (Lenis) + reveals (GSAP ScrollTrigger), con ciclo de vida de view transitions
      import { initMotion, destroyMotion } from '../scripts/motion.client';
      document.addEventListener('astro:page-load', initMotion);
      document.addEventListener('astro:before-swap', destroyMotion);
    </script>
  </body>
</html>
