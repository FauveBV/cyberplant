<!-- TIPOGRAFÍA -->
<section class="wrap" id="tipo">
  <div class="tag"><span class="n">04</span> Tipografía — mono base + display modular</div>
  <h2 style="margin-bottom:var(--sp-11)">Voz</h2>
  <div class="typegrid">
    <div class="typecell">
      <div class="label-sm">
        Display · modular sobre grilla <span class="pill">Syne · confirmada</span>
      </div>
      <div class="specimen">Aa<br />Gg</div>
      <p style="font-size:var(--fs-sm); color:var(--muted); margin-top:var(--sp-6)">
        Construida sobre módulos, no humanista. Coherente con "el texto como arquitectura".
        Definitiva: <b style="color:var(--line)">Syne</b>, dentro del lane modular/experimental, sobre
        la grilla del sistema.
      </p>
    </div>
    <div class="typecell">
      <div class="label-sm">Mono base · IBM Plex Mono / Iosevka</div>
      <div class="scale mono-spec">
        <div><span class="px">700</span><span style="font-weight:var(--fw-bold)">Discovery cerrado</span></div>
        <div><span class="px">500</span><span style="font-weight:var(--fw-medium)">Arquitectura / UX</span></div>
        <div><span class="px">400</span><span>Sistema de diseño bloqueado en v3</span></div>
        <div>
          <span class="px">400i</span><span style="font-style:italic">// el comentario también es diseño</span>
        </div>
        <div>
          <span class="px">300</span><span style="font-weight:var(--fw-light); color:var(--muted)"
            >$ git commit -m "tokens definitivos"</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
