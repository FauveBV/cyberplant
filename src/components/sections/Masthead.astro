---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const m = await reader.singletons.sistema.read();
if (!m) throw new Error('Falta el contenido de sistema (src/data/sistema.yaml).');
---

<!-- MASTHEAD -->
<header class="wrap mast">
  <div class="id">{m.id}</div>
  <h1>{m.titulo} <span class="blue">{m.acento}</span></h1>
  <p class="thesis">{m.thesis}</p>
  <div class="metaline">
    {m.metaline.map((x) => <span><b>{x.k}</b> · {x.v}</span>)}
  </div>
</header>
