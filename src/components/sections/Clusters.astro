---
import ClusterPreview from '../ClusterPreview.tsx';
---

<!-- CLUSTERS -->
<section class="wrap" id="clusters">
  <div class="tag"><span class="n">02</span> Fundamentos · Vocabulario — seis clusters del archivo visual</div>
  <h2 style="margin-bottom:var(--sp-11)">El vocabulario</h2>
  <div class="clusters">
    <div class="cluster">
      <div class="num">01</div>
      <h3>Tipografía estructural</h3>
      <div class="prev pv-type"></div>
      <span class="polo cold">humano</span>
      <p>El texto como arquitectura. Grilla visible, jerarquía explícita.</p>
    </div>
    <div class="cluster">
      <div class="num">02</div>
      <h3>Trazo y densidad</h3>
      <div class="prev pv-trazo"></div>
      <span class="polo cold">humano</span>
      <p>Línea acumulada, blueprint acotado, concept art, ASCII.</p>
    </div>
    <div class="cluster">
      <div class="num">03</div>
      <h3>Forma generativa</h3>
      <div class="prev"><ClusterPreview client:visible /></div>
      <span class="polo cold">núcleo</span>
      <p>Paramétrico, p5.js, visualización de datos. El motor de la firma.</p>
    </div>
    <div class="cluster">
      <div class="num">04</div>
      <h3>Glitch y dither</h3>
      <div class="prev pv-glitch"></div>
      <span class="polo cold">humano</span>
      <p>El error y el píxel hechos visibles. Textura nacida del sistema.</p>
    </div>
    <div class="cluster">
      <div class="num">05</div>
      <h3>Cartografía / dérive</h3>
      <div class="prev pv-carto"></div>
      <span class="polo warm">puente</span>
      <p>Situacionismo, psicogeografía. El territorio anotado que argumenta.</p>
    </div>
    <div class="cluster">
      <div class="num">06</div>
      <h3>Atmósfera + sobrecrecimiento</h3>
      <div class="prev pv-atm"></div>
      <span class="polo warm">natural</span>
      <p>Niebla, ambient y entornos abandonados colmados de vegetación.</p>
    </div>
  </div>
</section>
