---
/**
 * Skeleton — placeholder de carga (shimmer). Respeta reduced-motion.
 */
interface Props {
  width?: string;
  height?: string;
  class?: string;
}
const { width = '100%', height = '12px', class: extra } = Astro.props;
---

<div class:list={['skel', extra]} style={`width:${width};height:${height}`} aria-hidden="true"></div>

<style>
  .skel {
    background: linear-gradient(90deg, var(--color-surface) 25%, var(--overlay) 37%, var(--color-surface) 63%);
    background-size: 400% 100%;
    animation: sk 1.4s ease infinite;
  }
  @keyframes sk {
    0% {
      background-position: 100% 0;
    }
    100% {
      background-position: -100% 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .skel {
      animation: none;
    }
  }
</style>
