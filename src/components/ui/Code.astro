---
/**
 * Code — bloque de código mono. El contenido va por slot
 * (puede incluir <span class="c"> acento y <span class="g"> natural).
 */
interface Props {
  class?: string;
}
const { class: extra } = Astro.props;
---

<pre class:list={['code', extra]}><code><slot /></code></pre>

<style>
  .code {
    background: var(--bg);
    border: var(--bw) solid var(--color-border);
    padding: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    line-height: var(--lh-body);
    color: var(--line);
    overflow: auto;
  }
  .code :global(.c) {
    color: var(--color-accent-text);
  }
  .code :global(.g) {
    color: var(--color-natural-text);
  }
  .code :global(.s) {
    color: var(--color-signal-text);
  }
</style>
