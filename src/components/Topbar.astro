---
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

// normaliza quitando barra final
const path = pathname !== '/' ? pathname.replace(/\/$/, '') : '/';
const nav = [
  { href: '/sistema', label: 'sistema' },
  { href: '/cyberdeck', label: 'cyberdeck' },
  { href: '/portafolio', label: 'portafolio' },
  { href: '/bio', label: 'bio' },
];
---

<div class="topbar">
  <nav aria-label="Páginas" style="display:flex; gap:var(--sp-4); flex-wrap:wrap">
    <a class="gridbtn" href="/" aria-current={path === '/' ? 'page' : undefined}>inicio</a>
    {
      nav.map((n) => (
        <a
          class="gridbtn"
          href={n.href}
          aria-current={path === n.href || path.startsWith(n.href + '/') ? 'page' : undefined}
        >
          {n.label}
        </a>
      ))
    }
  </nav>
</div>

<style>
  .brand {
    color: inherit;
    text-decoration: none;
  }
  .brand:hover {
    text-decoration: none;
    color: var(--c-blue-text);
  }
  /* indicador de página activa, reusando el look del estado pressed de .gridbtn */
  a.gridbtn[aria-current='page'] {
    border-color: var(--c-blue-text);
    color: var(--c-blue-text);
    background: rgba(31, 61, 240, 0.12);
  }
</style>
