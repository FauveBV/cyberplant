  <div class="wrap footer-base">
    <span>© 2026 Fauve Bellenger</span>
    <span>Hecho con su propio sistema de diseño</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--bw) solid var(--overlay);
    margin-top: var(--sp-16);
    padding: var(--sp-16) 0 var(--sp-14);
    color: var(--muted);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--sp-12);
    align-items: start;
  }
  .footer-name {
    font-family: var(--display);
    font-weight: var(--fw-black);
    font-size: clamp(20px, 2.6vw, 32px);
    line-height: 0.95;
    letter-spacing: var(--tr-tightest);
    text-transform: uppercase;
    color: var(--line);
  }
  .footer-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
    color: var(--muted);
    margin-top: var(--sp-6);
    max-width: 42ch;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .footer-head {
    font-family: var(--mono);
    font-size: var(--fs-3xs);
    letter-spacing: var(--tr-widest);
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--sp-3);
    padding-bottom: var(--sp-3);
    border-bottom: var(--bw) solid var(--overlay);
  }
  .footer-col a {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    color: var(--txt);
    text-decoration: none;
  }
  .footer-col a:hover {
    color: var(--c-blue-text);
    text-decoration: none;
  }
  .footer-loc {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    color: var(--muted);
    margin-top: var(--sp-2);
  }
  .footer-base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-5);
    margin-top: var(--sp-14);
    padding-top: var(--sp-6);
    border-top: var(--bw) solid var(--overlay);
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tr-wide);
    color: var(--muted);
  }
  @media (max-width: 720px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-9);
    }
  }
</style>
